pipeline {
    agent any

    stages {
        stage('install') {
            steps {
                sh 'mvn install'
            }
        }

        stage('clean') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('deploy') {
            steps {
                archiveArtifacts artifacts: 'target/*.jar', followSymlinks: false
            }
        }
    }
}
